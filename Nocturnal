-- STATES
local mode = nil
local clicking = false
local altMoving = false
local altIgnore = nil
local resetCooldown = false
local triggerUsed = false

-- POSITIONS
local farmTarget = Vector3.new(-10.6566801,255.272766,-611.430786)
local triggerPoint = Vector3.new(4.31565142,255.272766,-627.21637)

local zone1 = Vector3.new(-6.06593323,256.009552,-599.597107)
local zone2 = Vector3.new(-33.4331932,256.009552,-593.822449)

local detectPoint = Vector3.new(66.7831879,251.986343,-609.299316)

local zoneDist = 8
local detectDist = 8
local triggerDist = 10

-- HELPERS
local function getChar()
	local c = player.Character
	if not c then return end
	return c, c:FindFirstChild("Humanoid"), c:FindFirstChild("HumanoidRootPart")
end

local function near(root,pos,dist)
	return (root.Position - pos).Magnitude <= dist
end

local function resetAll()
	mode = nil
	clicking = false
	altMoving = false
	altIgnore = nil
	triggerUsed = false

	mainBtn.Text = "MAIN: OFF"
	altBtn.Text = "ALT: OFF"
end

-- PATH
local function pathTo(target)
	local char,hum,root = getChar()
	if not char or not hum or not root then return end

	while mode and hum.Health > 0 do
		if (root.Position - target).Magnitude < 3 then return end

		local path = PathfindingService:CreatePath()
		path:ComputeAsync(root.Position,target)

		if path.Status ~= Enum.PathStatus.Success then
			hum.Jump = true
			task.wait(0.2)
			continue
		end

		for _,wp in pairs(path:GetWaypoints()) do
			if not mode then return end

			if wp.Action == Enum.PathWaypointAction.Jump then
				hum.Jump = true
			end

			hum:MoveTo(wp.Position)

			local t = tick()
			while tick()-t < 2 do
				if (root.Position - wp.Position).Magnitude < 3 then break end
				task.wait(0.1)
			end
		end
	end
end

-- AUTO CLICK
task.spawn(function()
	while true do
		if clicking and mode == "MAIN" then
			VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
			task.wait(0.03)
			VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
		end
		task.wait(0.05)
	end
end)

-- MAIN
RunService.Heartbeat:Connect(function()
	if mode ~= "MAIN" then return end

	local char,hum,root = getChar()
	if not char or not hum or not root then return end

	local inZone = near(root,zone1,zoneDist) or near(root,zone2,zoneDist)
	clicking = inZone

	if not inZone then
		pathTo(farmTarget)
	end
end)

-- 🔥 ALT (FIXED + TRIGGER SUPPORT)
RunService.Heartbeat:Connect(function()
	if mode ~= "ALT" then return end

	local char,hum,root = getChar()
	if not char or not hum or not root then return end

	-- 🔥 TRIGGER POINT FIX
	if not near(root, triggerPoint, triggerDist) then
		triggerUsed = false
	end

	if near(root, triggerPoint, triggerDist) and not triggerUsed then
		triggerUsed = true
		task.spawn(function()
			pathTo(farmTarget)
		end)
	end

	local z
	if near(root,zone1,zoneDist) then z=1 end
	if near(root,zone2,zoneDist) then z=2 end

	if not z then altIgnore=nil return end
	if z==altIgnore then return end
	if altMoving then return end

	altMoving=true

	task.spawn(function()
		if z==1 then
			pathTo(zone2)
			altIgnore=2
		elseif z==2 then
			pathTo(zone1)
			altIgnore=1
		end
		task.wait(0.2)
		altMoving=false
	end)
end)

-- DETECTION
task.spawn(function()
	while true do
		if mode and not resetCooldown then
			for _,p in pairs(Players:GetPlayers()) do
				if p~=player and p.Character then
					local r = p.Character:FindFirstChild("HumanoidRootPart")
					if r and near(r,detectPoint,detectDist) then
						resetCooldown=true
						showNotification()

						ReplicatedStorage:WaitForChild("Remote")
							:WaitForChild("ResetCharacterRequested")
							:FireServer()

						resetAll()

						task.wait(2)
						resetCooldown=false
						break
					end
				end
			end
		end
		task.wait(0.1)
	end
end)

