local dragging = false
local dragStart = nil
local startPos = nil
local dragMoved = false

toggleBox.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragMoved = false
		dragStart = input.Position
		startPos = toggleBox.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
				if not dragMoved then
					frame.Visible = not frame.Visible
				end
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if not dragging or not dragStart or not startPos then
		return
	end

	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
			dragMoved = true
		end

		if dragMoved then
			toggleBox.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end
end)

local character
local humanoid
local root

local function setupCharacter()
	character = player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")
	root = character:WaitForChild("HumanoidRootPart")
	pathToken += 1
	altIgnoreZone = nil
	altMoving = false
end

setupCharacter()
player.CharacterAdded:Connect(function()
	task.wait(0.2)
	setupCharacter()
end)

local function isAlive()
	return character and humanoid and root and humanoid.Health > 0 and character.Parent ~= nil
end

local function near(point, dist)
	return isAlive() and (root.Position - point).Magnitude <= dist
end

local function getZone()
	if near(zone1, zoneDistance) then
		return 1
	end
	if near(zone2, zoneDistance) then
		return 2
	end
	return nil
end

local function resetModes()
	mode = nil
	pathToken += 1
	altIgnoreZone = nil
	altMoving = false

	mainBtn.Text = "MAIN: OFF"
	mainBtn.BackgroundColor3 = Color3.fromRGB(170, 50, 50)
	altBtn.Text = "ALT: OFF"
	altBtn.BackgroundColor3 = Color3.fromRGB(170, 50, 50)
end

local function followPathTo(target, cancelIfZone)
	if not isAlive() then
		return
	end

	local myToken = pathToken

	while mode ~= nil and isAlive() and myToken == pathToken do
		if (root.Position - target).Magnitude <= reachDistance then
			return
		end

		if cancelIfZone and getZone() ~= nil then
			humanoid:Move(Vector3.zero, true)
			humanoid:MoveTo(root.Position)
			return
		end

		local path = PathfindingService:CreatePath({
			AgentRadius = 2,
			AgentHeight = 5,
			AgentCanJump = true,
			AgentJumpHeight = 7,
			AgentMaxSlope = 45,
			WaypointSpacing = 3
		})

		local ok = pcall(function()
			path:ComputeAsync(root.Position, target)
		end)

		if not ok or path.Status ~= Enum.PathStatus.Success then
			humanoid.Jump = true
			task.wait(0.2)
			continue
		end

		local blocked = false
		local blockedConn = path.Blocked:Connect(function()
			blocked = true
		end)

		local repath = false
		for _, waypoint in ipairs(path:GetWaypoints()) do
			if myToken ~= pathToken or mode == nil or not isAlive() then
				blockedConn:Disconnect()
				return
			end

			if cancelIfZone and getZone() ~= nil then
				humanoid:Move(Vector3.zero, true)
				humanoid:MoveTo(root.Position)
				blockedConn:Disconnect()
				return
			end

			if blocked then
				repath = true
				break
			end

			if waypoint.Action == Enum.PathWaypointAction.Jump then
				humanoid.Jump = true
			end

			if (root.Position - waypoint.Position).Magnitude > 2 then
				local startPosHere = root.Position
				humanoid:MoveTo(waypoint.Position)

				local reached = false
				local started = tick()

				while tick() - started < 2 do
					if myToken ~= pathToken or mode == nil or not isAlive() then
						blockedConn:Disconnect()
						return
					end

					if cancelIfZone and getZone() ~= nil then
						humanoid:Move(Vector3.zero, true)
						humanoid:MoveTo(root.Position)
						blockedConn:Disconnect()
						return
					end

					if blocked then
						repath = true
						break
					end

					if (root.Position - waypoint.Position).Magnitude <= 3 then
						reached = true
						break
					end

					if (root.Position - startPosHere).Magnitude < 1 and tick() - started > 0.8 then
						humanoid.Jump = true
					end

					task.wait(0.1)
				end

				if repath or not reached then
					repath = true
					break
				end
			end
		end

		blockedConn:Disconnect()

		if not repath and (root.Position - target).Magnitude <= reachDistance then
			return
		end

		task.wait(0.15)
	end
end

RunService.Heartbeat:Connect(function()
	if mode ~= "MAIN" or not isAlive() then
		return
	end

	local inZone = getZone() ~= nil

	if inZone then
		humanoid:Move(Vector3.zero, true)
		humanoid:MoveTo(root.Position)
	else
		task.spawn(function()
			followPathTo(farmTarget, true)
		end)
	end
end)

RunService.Heartbeat:Connect(function()
	if mode ~= "ALT" or not isAlive() then
		altMoving = false
		if mode ~= "ALT" then
			altIgnoreZone = nil
		end
		return
	end

	if near(triggerPoint, triggerDistance) then
		task.spawn(function()
			followPathTo(farmTarget, false)
		end)
		return
	end

	local zone = getZone()

	if zone == nil then
		altIgnoreZone = nil
		return
	end

	if altMoving or zone == altIgnoreZone then
		return
	end

	altMoving = true
	pathToken += 1

	task.spawn(function()
		local currentToken = pathToken
		if zone == 1 then
			followPathTo(zone2, false)
			if currentToken == pathToken then
				altIgnoreZone = 2
			end
		elseif zone == 2 then
			followPathTo(zone1, false)
			if currentToken == pathToken then
				altIgnoreZone = 1
			end
		end
		task.wait(0.2)
		altMoving = false
	end)
end)

task.spawn(function()
	while true do
		if mode ~= nil and not detectCooldown then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and plr.Character then
					local otherRoot = plr.Character:FindFirstChild("HumanoidRootPart")
					local otherHum = plr.Character:FindFirstChildOfClass("Humanoid")
					if otherRoot and otherHum and otherHum.Health > 0 then
						if (otherRoot.Position - detectPoint).Magnitude <= detectRadius then
							detectCooldown = true
							showNotification("⚠ Player detected near watch zone")
							resetModes()
							task.delay(2, function()
								detectCooldown = false
							end)
							break
						end
					end
				end
			end
		end
		task.wait(0.1)
	end
end)

